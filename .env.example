# Core runtime
TELECOM_BROWSER_MCP_TRANSPORT=stdio
TELECOM_BROWSER_MCP_HOST=127.0.0.1
TELECOM_BROWSER_MCP_PORT=8765
TELECOM_BROWSER_MCP_HEADLESS=true
TELECOM_BROWSER_MCP_DEFAULT_ADAPTER=generic_sipjs
TELECOM_BROWSER_MCP_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Artifact and evidence settings
TELECOM_BROWSER_MCP_ARTIFACT_ROOT=docs/audit/telecom-browser-mcp
TELECOM_BROWSER_MCP_REDACT=true
TELECOM_BROWSER_MCP_LOG_LEVEL=INFO
